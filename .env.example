NODE_ENV=development
LOCAL_POSTGRES_PORT=5433
# Use a project-specific local database name so multiple Payload repos do not
# point at the same local database. Example values:
# payload_acme_marketing, payload_internal_docs, payload_client_portal
PROJECT_DB_NAME=payload_starter
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/payload_starter
PAYLOAD_SECRET=replace-me-with-a-long-random-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_CORS_ORIGIN=http://localhost:3000

PAYLOAD_ENABLE_DB_MIGRATIONS=true
PAYLOAD_ENABLE_SEED=false

# Email transport mode:
# - console: log emails locally and skip SMTP entirely
# - smtp: send real email using the SMTP settings below
PAYLOAD_EMAIL_PROVIDER=console
# Backward-compatible legacy flag. Prefer PAYLOAD_EMAIL_PROVIDER.
PAYLOAD_SMTP_ENABLED=false
PAYLOAD_SMTP_HOST=
PAYLOAD_SMTP_PORT=587
PAYLOAD_SMTP_SECURE=false
PAYLOAD_SMTP_USER=
PAYLOAD_SMTP_PASSWORD=
PAYLOAD_EMAIL_FROM=Payload Starter <no-reply@example.com>
PAYLOAD_EMAIL_REPLY_TO=

PAYLOAD_STORAGE_PROVIDER=local
PAYLOAD_MEDIA_DIR=media

SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
